# Configuração do Banco de Dados
# O banco suporta PostgreSQL (oficialmente hospedado na Neon.tech) 
DATABASE_URL="postgresql://USUARIO:SENHA@HOST.neon.tech/NOME_BANCO?sslmode=require"

# Chave Criptográfica JWT
# Esta chave deve ser forte e longa para produção (gerada em um password manager, 64+ caracteres)
JWT_SECRET="insira-sua-chave-secreta-forte-aqui-producao"

# Toggle de Inicialização WhatsApp
# Defina como "false" para iniciar o painel/backend sem ativar o navegador Chromium do WhatsApp
WHATSAPP_ENABLED="true"
