// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Cliente {
  id              String   @id @default(uuid())
  nome            String
  email           String
  telefone        String
  ultimoContato   DateTime @default(now())
  totalOrcamentos Int      @default(0)
  
  // Relations
  usuarioId       String
  usuario         Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  orcamentos      Orcamento[]
}

model Orcamento {
  id             String   @id @default(uuid())
  descricao      String
  valor          Float
  status         String   @default("pendente")
  dataRecebido   DateTime @default(now())
  dataAtualizado DateTime @updatedAt

  // Foreign key relation
  clienteId      String
  cliente        Cliente @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  usuarioId      String
  usuario        Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  
  // Relations
  eventos        OrcamentoEvento[]
}

model OrcamentoEvento {
  id             String   @id @default(uuid())
  orcamentoId    String
  orcamento      Orcamento @relation(fields: [orcamentoId], references: [id], onDelete: Cascade)
  
  tipo           String   // "criado", "status_alterado", "atualizado"
  descricao      String
  statusAntigo   String?  // Anterior status para mudanças
  statusNovo     String?  // Novo status para mudanças
  
  criadoEm       DateTime @default(now())
  
  @@index([orcamentoId])
}

model Configuracao {
  id               String   @id @default(uuid())
  usuarioId        String   @unique
  usuario          Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  
  corPrimaria      String   @default("224.3 76.3% 48%") // hsl string padrão
  tema             String   @default("system")
  
  // Templates de WhatsApp
  templateProposta       String @default("Olá {{cliente}}, tudo bem? \n\nConforme conversamos, o valor estimado para o serviço fica em *{{valor}}*.\n\nO escopo inclui:\n{{descricao}}\n\nPodemos dar andamento? Qualquer dúvida estou à disposição!")
  templateLembrete       String @default("Oi {{cliente}}, passando para saber se você conseguiu dar uma olhadinha na nossa proposta ou se ficou com alguma dúvida! 😊")
  templateAgradecimento  String @default("Muito obrigado por fechar conosco, {{cliente}}! Vamos fazer um trabalho incrível. Em breve envio os próximos passos.")
  
  atualizadoEm     DateTime @updatedAt
}

model Usuario {
  id               String   @id @default(uuid())
  nome             String
  email            String   @unique
  senha            String   // Senha hasheada com bcrypt
  empresa          String?  // Nome da Empresa/Agência
  telefone         String?  // Telefone da Empresa
  createdAt        DateTime @default(now())
  
  // Relations
  clientes         Cliente[]
  orcamentos       Orcamento[]
  configuracao     Configuracao?
}
